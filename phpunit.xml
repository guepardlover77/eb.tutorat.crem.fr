<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <!-- Laravel Breeze boilerplate — not application-specific logic -->
            <directory>app/Http/Controllers/Auth</directory>
            <directory>app/View/Components</directory>
            <directory>app/Http/Requests</directory>
            <file>app/Http/Controllers/ProfileController.php</file>
            <!-- OAuth redirect — requires Socialite mock, no business logic -->
            <file>app/Http/Controllers/GoogleAuthController.php</file>
            <!-- External HTTP client — tested indirectly via SyncService mocks -->
            <file>app/Services/HelloAssoService.php</file>
            <!-- Requires a real Excel file on disk — not suitable for CI unit tests -->
            <file>app/Services/SeatLayoutService.php</file>
            <!-- Artisan commands are thin wrappers around services already tested -->
            <directory>app/Console/Commands</directory>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="HELLOASSO_CLIENT_ID" value="test_client_id"/>
        <env name="HELLOASSO_CLIENT_SECRET" value="test_client_secret"/>
    </php>
</phpunit>
